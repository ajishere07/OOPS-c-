	public class BankingService{
		private readonly IAccountRepository repository;
		private readonly INotification notification;
		private readonly IReceiptPrinter printer;

		public BankingService(
		IAccountRepository repository,
		INotification notification,
		IReceiptPrinter printer){
			this.repository = repository;
			this.notification = notification;
			this.printer = printer;
		}


		public void OpenAccount(BankAccount account){
          repository.Save(account);
		  notification.Send(account);
		  printer.Print(account);	
		}

	}
	public interface IDepositable{
		void Deposit(decimal amount);
	}

	public interface IWithdrawable{
		void Withdraw(decimal amount);
	}


	public interface INotification{
		void Send(BankAccount account);
	}

	public class SMSNotification : INotification{
		public void Send(BankAccount account){
			Console.WriteLine($"SMS sent to {account.AccountHolder}");
		}
	}

	public class EmailNotification  : INotification{
		public void Send(BankAccount account){
			Console.WriteLine($"Email sent to {account.AccountHolder}");
		}
	}

