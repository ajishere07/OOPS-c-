	public class SavingsAccount : BankAccount, IWithdrawable, IDepositable {
		public SavingsAccount(string accountHolder): base(accountHolder){}
			public void Deposit(decimal amount){
				Balance += amount;
				Console.WriteLine($"{amount} deposited.");
			}
            public void Withdraw(decimal amount){
                if(Balance >= amount){
		            Balance -= amount;
				    Console.WriteLine($"{amount} withdrawn.");
			    }else{
				    Console.WriteLine("Insufficient balance.");
		     	}
			}
			
		}


		public class FixedDepositAccount : BankAccount, IDepositable{
			public FixedDepositAccount(string accountHolder): base(accountHolder){}
			public void Deposit(decimal amount)
			{
				Balance += amount;
				Console.WriteLine($"{amount} deposited.");
			}
		}	



